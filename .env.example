# ---------------------------------------------------------------------------
# LOB Matching Engine — Environment Variables
# Copy to .env and fill in values before running.
# ---------------------------------------------------------------------------

# PostgreSQL
POSTGRES_USER=lob
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=lobdb
POSTGRES_PORT=5432

# Constructed from above (used by the app directly)
DATABASE_URL=postgresql://lob:changeme_in_production@localhost:5432/lobdb

# Redis (optional — used for pub/sub to external consumers)
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# API
API_PORT=8000
LOG_LEVEL=info           # debug | info | warning | error
DB_ECHO=false            # Set to true to log all SQL queries

# CORS — comma-separated origins (use * for development only)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
